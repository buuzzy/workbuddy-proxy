# WorkBuddy Proxy 配置
# 复制此文件为 .env 并按需修改

# 代理监听端口
PROXY_PORT=19090

# 客户端使用的 API Key（自定义，用于保护代理接口）
PROXY_API_KEY=wb-proxy-key

# WorkBuddy API 地址（通常不需要修改）
# WB_API_BASE=https://copilot.tencent.com

# CDP 调试地址（用于自动提取 Token）
# 本地运行用 127.0.0.1，Docker 中用 host.docker.internal
# CDP_URL=http://127.0.0.1:9222

# 上游请求超时（秒）
# WB_TIMEOUT=120              # 普通模型（默认 120s）
# WB_REASONING_TIMEOUT=300    # 推理模型如 deepseek-r1（默认 300s）

# --- 以下为可选项，通常无需手动设置（会从 JWT 自动解析） ---
# WB_TOKEN=<your-jwt-access-token>
# WB_REFRESH_TOKEN=<your-refresh-token>
# WB_USER_ID=<auto-detected>
# WB_ENTERPRISE_ID=<auto-detected>
# WB_DOMAIN=<auto-detected>
